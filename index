  const typeBadge={Allied:'badge-green',Neutral:'badge-gray',Hostile:'badge-red',Pending:'badge-yellow',Dissolved:'badge-gray'};
  grid.innerHTML=filtered.map((a,fi)=>{
    const i=S.alliances.indexOf(a);const col=ALLIANCE_COLORS[a.type]||'#7878a0';

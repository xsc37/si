      <div class="nav-item" data-tab="settings"><span class="nav-icon">⚙</span>Settings</div>
      <div class="sidebar-footer">
        <div style="display:flex;gap:.4rem;margin-bottom:.5rem;">
          <button class="btn btn-lav btn-sm" onclick="exportData()" style="flex:1;clip-path:none;">Export</button>
          <label class="btn btn-ghost btn-sm" style="flex:1;cursor:pointer;clip-path:none;display:flex;align-items:center;justify-content:center;">
            Import<input type="file" accept=".json" onchange="importData(event)" style="display:none;">
          </label>

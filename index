
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SEVRE INDUSTRIES — OPS CORE v2.5</title>
<link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@200;300;400;500;600;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{
  --bg0:#09090c;--bg1:#0e0e13;--bg2:#13131a;--bg3:#1a1a24;--bg4:#20202e;
  --red:#9c2030;--red2:#c02840;--red-glow:rgba(156,32,48,0.18);
  --lav:#7a6fa8;--lav2:#9d90cc;--lav-glow:rgba(122,111,168,0.15);
  --txt:#cccce0;--txt2:#7878a0;--txt3:#404060;
  --brd:#22223a;--brd2:#2e2e48;--card:#131320;
  --scanline-opacity:0.08;
  font-family:'Exo 2',sans-serif;
}
body.light{
  --bg0:#eeeef6;--bg1:#e6e6f0;--bg2:#dcdce8;--bg3:#d0d0e0;--bg4:#c8c8d8;
  --txt:#18182c;--txt2:#48486a;--txt3:#8888a8;
  --brd:#c0c0d8;--brd2:#b0b0cc;--card:#e8e8f2;--scanline-opacity:0.03;
}
body.light .topbar{background:rgba(232,232,242,0.98);}
body.light .sidebar{background:rgba(224,224,238,0.98);}
body.light #login{background:radial-gradient(ellipse at 50% 60%,#d8c0e0 0%,#eeeef6 60%,#e4e4f0 100%);}
body.light .login-box{background:rgba(230,230,244,0.98);}
body.light .form-input,body.light .form-select,body.light .form-textarea{background:rgba(255,255,255,.6);color:var(--txt);}
body.light .form-select option{background:var(--bg2);color:var(--txt);}
body.light .modal{background:var(--bg2);}
body.light .gube-eq{background:var(--bg3);}
body.light .event-row input{background:rgba(255,255,255,.4);color:var(--txt);}
body.light .drop-zone{background:rgba(255,255,255,.3);}
body.light .sfn-header{background:linear-gradient(135deg,rgba(156,32,48,.08),transparent);}
body.light .tracker-search{background:rgba(255,255,255,.4);color:var(--txt);}
body.light .settings-preview{background:var(--bg3);}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg0);color:var(--txt);min-height:100vh;overflow:hidden;transition:background .3s,color .3s;}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,var(--scanline-opacity)) 2px,rgba(0,0,0,var(--scanline-opacity)) 4px);}
/* LOGIN */
#login{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;
  background:radial-gradient(ellipse at 50% 60%,#1a0810 0%,#09090c 60%,#070709 100%);transition:background .3s;}
#login::after{content:'SËVËRA';position:absolute;bottom:2rem;right:2.5rem;font-size:.6rem;letter-spacing:.4em;
  color:rgba(156,32,48,0.12);font-family:'Space Mono',monospace;text-transform:uppercase;}
.login-box{position:relative;background:rgba(14,14,19,0.96);border:1px solid var(--red);
  padding:2.5rem 2.8rem;width:380px;
  box-shadow:0 0 40px rgba(156,32,48,.2),inset 0 0 60px rgba(0,0,0,.5);
  clip-path:polygon(0 0,calc(100% - 24px) 0,100% 24px,100% 100%,24px 100%,0 calc(100% - 24px));}
.login-box::before{content:'';position:absolute;top:0;right:0;width:24px;height:24px;border-top:1px solid var(--red2);border-right:1px solid var(--red2);}
.login-box::after{content:'';position:absolute;bottom:0;left:0;width:24px;height:24px;border-bottom:1px solid var(--red2);border-left:1px solid var(--red2);}
.login-logo{font-size:1.05rem;font-weight:800;letter-spacing:.35em;color:var(--red2);text-transform:uppercase;margin-bottom:.3rem;text-align:center;}
.login-sub{font-size:.6rem;letter-spacing:.25em;color:var(--txt2);text-align:center;margin-bottom:2rem;font-family:'Space Mono',monospace;}
.login-label{font-size:.6rem;letter-spacing:.2em;color:var(--txt2);margin-bottom:.4rem;display:block;font-family:'Space Mono',monospace;}
.login-input{width:100%;background:rgba(0,0,0,.5);border:1px solid var(--brd2);color:var(--txt);
  padding:.7rem 1rem;font-family:'Space Mono',monospace;font-size:.8rem;margin-bottom:1.2rem;outline:none;transition:border-color .2s,box-shadow .2s;}
.login-input:focus{border-color:var(--red);box-shadow:0 0 12px var(--red-glow);}
.login-btn{width:100%;padding:.8rem;background:var(--red);color:#fff;border:none;cursor:pointer;
  font-family:'Exo 2',sans-serif;font-weight:700;font-size:.85rem;letter-spacing:.2em;text-transform:uppercase;transition:all .2s;
  clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));}
.login-btn:hover{background:var(--red2);box-shadow:0 0 20px var(--red-glow);}
.login-err{color:var(--red2);font-size:.65rem;text-align:center;margin-top:.8rem;letter-spacing:.1em;font-family:'Space Mono',monospace;min-height:1rem;}
.boot-lines{font-family:'Space Mono',monospace;font-size:.6rem;color:var(--txt3);line-height:1.8;margin-bottom:1.5rem;}
.boot-line{opacity:0;animation:bootIn .15s forwards;}
@keyframes bootIn{to{opacity:1;}}
/* APP */
#app{display:none;height:100vh;overflow:hidden;flex-direction:column;}
#app.active{display:flex;}
/* TOPBAR */
.topbar{height:36px;background:rgba(9,9,12,0.98);border-bottom:1px solid var(--brd);
  display:flex;align-items:center;padding:0 1rem;gap:1rem;flex-shrink:0;z-index:100;transition:background .3s;}
.topbar-brand{font-size:.65rem;font-weight:800;letter-spacing:.3em;color:var(--red);text-transform:uppercase;}
.topbar-sep{width:1px;height:16px;background:var(--brd2);}
.topbar-user{font-size:.6rem;font-family:'Space Mono',monospace;color:var(--txt2);}
.topbar-user span{color:var(--lav2);}
.topbar-time{font-size:.58rem;font-family:'Space Mono',monospace;color:var(--txt3);margin-left:auto;}
.topbar-status{display:flex;align-items:center;gap:.4rem;font-size:.55rem;font-family:'Space Mono',monospace;color:var(--txt2);}
.status-dot{width:5px;height:5px;background:#2dff6e;border-radius:50%;box-shadow:0 0 6px #2dff6e;animation:pulse2 2s infinite;}
@keyframes pulse2{0%,100%{opacity:1;}50%{opacity:.4;}}
.theme-toggle{display:flex;align-items:center;gap:.4rem;cursor:pointer;padding:.2rem .5rem;border:1px solid var(--brd2);transition:border-color .2s;}
.theme-toggle:hover{border-color:var(--lav);}
.theme-toggle-icon{font-size:.8rem;}
.theme-toggle-label{font-size:.55rem;font-family:'Space Mono',monospace;color:var(--txt2);letter-spacing:.1em;}
.topbar-icon-btn{background:none;border:1px solid var(--brd2);color:var(--txt2);cursor:pointer;padding:.2rem .45rem;font-size:.75rem;transition:all .15s;}
.topbar-icon-btn:hover{border-color:var(--red);color:var(--red2);}
.workspace{display:flex;flex:1;overflow:hidden;}
/* SIDEBAR */
.sidebar{width:190px;background:rgba(10,10,15,0.98);border-right:1px solid var(--brd);
  display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;padding:8px 0;transition:background .3s;}
.sidebar::-webkit-scrollbar{width:3px;}
.sidebar::-webkit-scrollbar-thumb{background:var(--brd2);}
.nav-section{padding:.5rem .8rem .2rem;font-size:.5rem;letter-spacing:.25em;color:var(--txt3);font-family:'Space Mono',monospace;text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:.6rem;padding:.55rem .9rem;cursor:pointer;font-size:.72rem;font-weight:500;color:var(--txt2);letter-spacing:.05em;transition:all .15s;border-left:2px solid transparent;}
.nav-item:hover{color:var(--txt);background:rgba(122,111,168,.05);}
.nav-item.active{color:var(--red2);border-left-color:var(--red);background:rgba(156,32,48,.08);}
.nav-icon{font-size:.85rem;width:18px;text-align:center;}
.nav-badge{margin-left:auto;background:var(--red);color:#fff;font-size:.5rem;padding:1px 5px;border-radius:2px;font-family:'Space Mono',monospace;}
.sidebar-footer{margin-top:auto;padding:.8rem;border-top:1px solid var(--brd);}
.logout-btn{width:100%;padding:.45rem;background:transparent;border:1px solid var(--brd2);color:var(--txt2);font-family:'Exo 2',sans-serif;font-size:.65rem;cursor:pointer;letter-spacing:.15em;transition:all .2s;}
.logout-btn:hover{border-color:var(--red);color:var(--red);}
/* MAIN */
.main{flex:1;overflow:hidden;display:flex;flex-direction:column;}
.tab-panel{display:none;height:100%;overflow-y:auto;padding:.8rem 1.2rem .8rem .8rem;position:relative;}
.tab-panel.active{display:block;}
.tab-panel::-webkit-scrollbar{width:4px;}
.tab-panel::-webkit-scrollbar-thumb{background:var(--brd2);}
.easter{position:absolute;bottom:.8rem;right:1rem;font-size:.55rem;letter-spacing:.3em;color:rgba(122,111,168,0.12);font-family:'Space Mono',monospace;pointer-events:none;user-select:none;text-transform:uppercase;}
/* SHARED */
.page-header{display:flex;align-items:flex-end;gap:1rem;margin-bottom:.7rem;padding-bottom:.6rem;border-bottom:1px solid var(--brd);}
.page-title{font-size:1.05rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase;color:var(--txt);}
.page-title span{color:var(--red);}
.page-sub{font-size:.58rem;font-family:'Space Mono',monospace;color:var(--txt3);letter-spacing:.1em;margin-bottom:2px;}
.page-actions{margin-left:auto;display:flex;gap:.5rem;align-items:center;}
.btn{padding:.42rem .9rem;border:1px solid;cursor:pointer;font-family:'Exo 2',sans-serif;font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;transition:all .2s;clip-path:polygon(0 0,calc(100% - 7px) 0,100% 7px,100% 100%,7px 100%,0 calc(100% - 7px));}
.btn-red{background:var(--red);border-color:var(--red);color:#fff;}
.btn-red:hover{background:var(--red2);box-shadow:0 0 14px var(--red-glow);}
.btn-lav{background:transparent;border-color:var(--lav);color:var(--lav2);}
.btn-lav:hover{background:rgba(122,111,168,.1);box-shadow:0 0 10px var(--lav-glow);}
.btn-ghost{background:transparent;border-color:var(--brd2);color:var(--txt2);}
.btn-ghost:hover{border-color:var(--txt2);color:var(--txt);}
.btn-danger{background:transparent;border-color:#6a1020;color:#c0304a;}
.btn-danger:hover{background:rgba(106,16,32,.2);}
.btn-sm{padding:.3rem .6rem;font-size:.6rem;}
.card{background:var(--card);border:1px solid var(--brd);padding:1rem;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));position:relative;transition:background .3s;}
.card-corner{position:absolute;top:0;right:0;width:12px;height:12px;border-top:1px solid var(--red);border-right:1px solid var(--red);}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:.7rem;}
.stat-card{background:var(--card);border:1px solid var(--brd);padding:.8rem 1rem;position:relative;overflow:hidden;transition:background .3s;}
.stat-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--red);}
.stat-val{font-size:1.6rem;font-weight:800;color:var(--red2);line-height:1;}
.stat-lbl{font-size:.55rem;letter-spacing:.2em;color:var(--txt2);text-transform:uppercase;margin-top:.3rem;font-family:'Space Mono',monospace;}
.badge{display:inline-block;padding:.15rem .4rem;font-size:.55rem;letter-spacing:.1em;font-family:'Space Mono',monospace;text-transform:uppercase;}
.badge-red{background:rgba(156,32,48,.2);color:var(--red2);border:1px solid rgba(156,32,48,.3);}
.badge-lav{background:rgba(122,111,168,.15);color:var(--lav2);border:1px solid rgba(122,111,168,.25);}
.badge-green{background:rgba(45,200,110,.1);color:#3dcc80;border:1px solid rgba(45,200,110,.2);}
.badge-gray{background:rgba(100,100,120,.15);color:var(--txt2);border:1px solid var(--brd2);}
.badge-yellow{background:rgba(255,180,0,.1);color:#ffb400;border:1px solid rgba(255,180,0,.25);}
/* MODALS */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:500;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-overlay.open{display:flex;}
.modal{background:var(--bg2);border:1px solid var(--brd2);width:480px;max-width:90vw;
  clip-path:polygon(0 0,calc(100% - 20px) 0,100% 20px,100% 100%,20px 100%,0 calc(100% - 20px));animation:modalIn .2s ease;}
@keyframes modalIn{from{transform:scale(.95) translateY(-10px);opacity:0;}to{transform:scale(1);opacity:1;}}
.modal-head{padding:.8rem 1.2rem;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:.8rem;}
.modal-title{font-size:.8rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;}
.modal-close{margin-left:auto;background:none;border:none;color:var(--txt2);cursor:pointer;font-size:1rem;transition:color .15s;}
.modal-close:hover{color:var(--red2);}
.modal-body{padding:1.2rem;}
.form-group{margin-bottom:.9rem;}
.form-label{display:block;font-size:.58rem;letter-spacing:.18em;color:var(--txt2);margin-bottom:.35rem;font-family:'Space Mono',monospace;text-transform:uppercase;}
.form-input,.form-select,.form-textarea{width:100%;background:rgba(0,0,0,.4);border:1px solid var(--brd2);color:var(--txt);padding:.55rem .8rem;font-family:'Exo 2',sans-serif;font-size:.78rem;outline:none;transition:border-color .2s;border-radius:0;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--red);box-shadow:0 0 8px var(--red-glow);}
.form-select{cursor:pointer;}
.form-textarea{resize:vertical;min-height:70px;}
.form-select option{background:var(--bg2);}
.modal-foot{padding:.8rem 1.2rem;border-top:1px solid var(--brd);display:flex;gap:.6rem;justify-content:flex-end;}
/* DASHBOARD */
.dash-hero{background:var(--bg2);border:1px solid var(--brd);padding:1.2rem;margin-bottom:.8rem;position:relative;overflow:hidden;clip-path:polygon(0 0,calc(100% - 24px) 0,100% 24px,100% 100%,0 100%);}
.dash-hero::before{content:'';position:absolute;top:0;right:0;width:200px;height:100%;background:linear-gradient(to left,rgba(156,32,48,.06),transparent);pointer-events:none;}
.dash-hero-title{font-size:1.4rem;font-weight:800;letter-spacing:.2em;text-transform:uppercase;color:var(--txt);line-height:1.1;}
.dash-hero-title em{color:var(--red);font-style:normal;}
.dash-hero-sub{font-size:.6rem;font-family:'Space Mono',monospace;color:var(--txt2);margin-top:.4rem;letter-spacing:.12em;}
.dash-hero-corner{position:absolute;top:0;right:0;width:24px;height:24px;border-top:1px solid var(--red2);border-right:1px solid var(--red2);}
.ps5-row{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:.8rem;margin-bottom:.8rem;}
.ps5-card{background:var(--card);border:1px solid var(--brd);padding:.9rem;position:relative;overflow:hidden;cursor:pointer;transition:all .2s;}
.ps5-card:hover{border-color:var(--red);}
.ps5-card-label{font-size:.55rem;letter-spacing:.2em;color:var(--txt2);text-transform:uppercase;font-family:'Space Mono',monospace;margin-bottom:.4rem;}
.ps5-card-val{font-size:1.8rem;font-weight:800;color:var(--txt);line-height:1;}
.ps5-card-sub{font-size:.58rem;color:var(--txt2);margin-top:.2rem;}
.ps5-card-bar{height:2px;background:var(--brd);margin-top:.7rem;}
.ps5-card-bar-fill{height:100%;background:var(--red);transition:width 1s ease;}
.activity-feed{background:var(--card);border:1px solid var(--brd);padding:.8rem;}
.feed-title{font-size:.58rem;letter-spacing:.2em;color:var(--txt2);text-transform:uppercase;font-family:'Space Mono',monospace;margin-bottom:.6rem;border-bottom:1px solid var(--brd);padding-bottom:.4rem;}
.feed-item{display:flex;gap:.6rem;padding:.35rem 0;border-bottom:1px solid rgba(34,34,58,.3);font-size:.65rem;align-items:flex-start;}
.feed-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:.25rem;}
.feed-dot.red{background:var(--red2);}.feed-dot.lav{background:var(--lav);}.feed-dot.green{background:#2dcc70;}
.feed-time{font-family:'Space Mono',monospace;color:var(--txt3);font-size:.55rem;white-space:nowrap;}
/* OPERATORS */
.ops-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:.7rem;margin-top:.6rem;}
.op-card{background:var(--card);border:1px solid var(--brd);padding:.9rem;cursor:pointer;position:relative;overflow:hidden;transition:all .2s;clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,0 100%);}
.op-card:hover{border-color:var(--red);transform:translateY(-2px);}
.op-avatar{width:36px;height:36px;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:1rem;margin-bottom:.6rem;border:1px solid var(--brd2);clip-path:polygon(0 0,calc(100% - 6px) 0,100% 6px,100% 100%,0 100%);}
.op-name{font-size:.72rem;font-weight:700;color:var(--txt);margin-bottom:.2rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.op-role{font-size:.58rem;color:var(--txt2);margin-bottom:.4rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.op-corner{position:absolute;top:0;right:0;width:10px;height:10px;border-top:1px solid var(--red);border-right:1px solid var(--red);}
.op-actions{display:flex;gap:.3rem;margin-top:.4rem;opacity:0;transition:opacity .2s;}
.op-card:hover .op-actions{opacity:1;}
/* PROJECTS */
.proj-item{background:var(--card);border:1px solid var(--brd);padding:.8rem 1rem;margin-bottom:.5rem;display:flex;align-items:center;gap:.8rem;position:relative;}
.proj-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--red);opacity:.4;}
.proj-check{appearance:none;width:14px;height:14px;border:1px solid var(--brd2);cursor:pointer;background:transparent;flex-shrink:0;}
.proj-check:checked{background:var(--red);border-color:var(--red);}
.proj-name{font-size:.78rem;font-weight:600;flex:1;}
.proj-bar{flex:1;max-width:120px;height:3px;background:var(--bg3);border-radius:2px;}
.proj-bar-fill{height:100%;background:linear-gradient(90deg,var(--red),var(--lav));border-radius:2px;transition:width .8s ease;}
.proj-actions{display:flex;gap:.4rem;opacity:0;transition:opacity .2s;}
.proj-item:hover .proj-actions{opacity:1;}
/* GROWTH */
.milestone-item{background:var(--card);border:1px solid var(--brd);padding:.7rem 1rem;margin-bottom:.4rem;display:flex;align-items:center;gap:.8rem;}
.milestone-check{width:18px;height:18px;border:1px solid var(--brd2);display:flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0;cursor:pointer;}
.milestone-check.done{border-color:var(--red);color:var(--red);background:rgba(156,32,48,.1);}
.milestone-name{font-size:.75rem;flex:1;}
.milestone-name.done{text-decoration:line-through;color:var(--txt2);}
.chart-wrap{background:var(--card);border:1px solid var(--brd);padding:.8rem;margin-bottom:.8rem;}
.chart-wrap canvas{max-height:200px;}
.chart-label{font-size:.58rem;letter-spacing:.2em;color:var(--txt2);text-transform:uppercase;font-family:'Space Mono',monospace;margin-bottom:.5rem;}
/* GUBE */
.gube-panel{display:grid;grid-template-columns:280px 1fr;gap:.8rem;height:calc(100% - 60px);}
.gube-config{background:var(--card);border:1px solid var(--brd);padding:.9rem;overflow-y:auto;}
.gube-output{display:flex;flex-direction:column;gap:.6rem;overflow-y:auto;}
.gube-eq{background:var(--bg3);border:1px solid var(--brd2);padding:.7rem;font-family:'Space Mono',monospace;font-size:.6rem;color:var(--lav2);margin-bottom:.7rem;line-height:1.8;}
.gube-slider{width:100%;accent-color:var(--red);margin:.2rem 0;}
.gube-slider-val{font-family:'Space Mono',monospace;color:var(--red2);font-size:.65rem;float:right;}
.event-row{display:flex;gap:.4rem;align-items:center;margin-bottom:.4rem;}
.event-row input{flex:1;background:rgba(0,0,0,.3);border:1px solid var(--brd);color:var(--txt);padding:.3rem .5rem;font-size:.65rem;font-family:'Space Mono',monospace;outline:none;}
.event-row input:focus{border-color:var(--red);}
.gube-state-bar{display:flex;align-items:center;gap:.6rem;margin-bottom:.3rem;font-size:.6rem;font-family:'Space Mono',monospace;}
.gube-state-fill{height:8px;border-radius:1px;transition:width .3s ease;}
.case-0 .gube-state-fill{background:var(--red2);}.case-1 .gube-state-fill{background:var(--lav2);}.case-2 .gube-state-fill{background:#3dcc80;}
.stability-indicator{padding:.5rem .8rem;font-family:'Space Mono',monospace;font-size:.65rem;border:1px solid;margin-bottom:.6rem;}
.stability-stable{border-color:rgba(45,200,110,.4);background:rgba(45,200,110,.06);color:#3dcc80;}
.stability-warning{border-color:rgba(255,180,0,.4);background:rgba(255,180,0,.06);color:#ffb400;}
.stability-unstable{border-color:rgba(156,32,48,.5);background:rgba(156,32,48,.08);color:var(--red2);}
/* SFN */
.sfn-header{background:linear-gradient(135deg,rgba(156,32,48,.12),transparent);border:1px solid var(--red);padding:1rem;margin-bottom:.8rem;clip-path:polygon(0 0,calc(100% - 18px) 0,100% 18px,100% 100%,0 100%);}
.sfn-name{font-size:1rem;font-weight:800;letter-spacing:.25em;color:var(--red2);}
.sfn-desc{font-size:.6rem;font-family:'Space Mono',monospace;color:var(--txt2);margin-top:.2rem;}
.sfn-asset-counter{display:flex;align-items:center;gap:1rem;margin-bottom:.8rem;}
.sfn-asset-val{font-size:2.5rem;font-weight:800;color:var(--red2);font-family:'Space Mono',monospace;text-shadow:0 0 20px rgba(156,32,48,.4);}
.sfn-asset-btns{display:flex;flex-direction:column;gap:.4rem;}
.sfn-member-table{width:100%;border-collapse:collapse;font-size:.7rem;}
.sfn-member-table th{padding:.4rem .6rem;font-size:.52rem;letter-spacing:.18em;color:var(--txt2);border-bottom:1px solid var(--brd2);font-weight:400;font-family:'Space Mono',monospace;text-transform:uppercase;}
.sfn-member-table td{padding:.45rem .6rem;border-bottom:1px solid rgba(34,34,58,.4);}
/* ALLIANCE */
.alliance-stats{display:grid;grid-template-columns:repeat(5,1fr);gap:.6rem;margin-bottom:.8rem;}
.alliance-stat{background:var(--card);border:1px solid var(--brd);padding:.6rem .8rem;text-align:center;position:relative;overflow:hidden;}
.alliance-stat::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--red);}
.alliance-stat-val{font-size:1.2rem;font-weight:800;color:var(--red2);}
.alliance-stat-lbl{font-size:.5rem;letter-spacing:.15em;color:var(--txt2);text-transform:uppercase;font-family:'Space Mono',monospace;margin-top:.15rem;}
.alliance-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.7rem;}
.alliance-card{background:var(--card);border:1px solid var(--brd);padding:.9rem;position:relative;overflow:hidden;cursor:pointer;transition:all .2s;clip-path:polygon(0 0,calc(100% - 14px) 0,100% 14px,100% 100%,0 100%);}
.alliance-card:hover{border-color:var(--red);transform:translateY(-2px);}
.alliance-card-corner{position:absolute;top:0;right:0;width:14px;height:14px;border-top:1px solid var(--red);border-right:1px solid var(--red);}
.alliance-card-bar{position:absolute;top:0;left:0;width:3px;height:100%;}
.alliance-name{font-size:.82rem;font-weight:700;color:var(--txt);margin-bottom:.3rem;}
.alliance-meta{font-size:.58rem;color:var(--txt2);font-family:'Space Mono',monospace;margin-bottom:.4rem;}
.alliance-tier-stars{font-size:.7rem;letter-spacing:.05em;margin-bottom:.4rem;}
.alliance-contact{font-size:.62rem;color:var(--txt2);margin-bottom:.3rem;}
.alliance-footer{display:flex;align-items:center;justify-content:space-between;margin-top:.5rem;padding-top:.4rem;border-top:1px solid var(--brd);}
.alliance-actions{display:flex;gap:.3rem;opacity:0;transition:opacity .2s;}
.alliance-card:hover .alliance-actions{opacity:1;}
/* TRACKER */
.tracker-header{background:var(--card);border:1px solid var(--brd);padding:.7rem 1rem;margin-bottom:.7rem;display:flex;align-items:center;gap:.8rem;}
.tracker-search{flex:1;background:rgba(0,0,0,.3);border:1px solid var(--brd);color:var(--txt);padding:.4rem .7rem;font-family:'Exo 2',sans-serif;font-size:.72rem;outline:none;}
.tracker-search:focus{border-color:var(--lav);}
.tracker-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:.6rem;}
.tracker-card{background:var(--card);border:1px solid var(--brd);padding:.8rem;cursor:pointer;transition:all .2s;position:relative;}
.tracker-card:hover{border-color:var(--lav);transform:translateY(-2px);}
.tracker-icon{font-size:1.6rem;margin-bottom:.5rem;}
.tracker-name{font-size:.72rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tracker-meta{font-size:.58rem;color:var(--txt2);font-family:'Space Mono',monospace;margin-top:.2rem;}
.tracker-size{position:absolute;top:.5rem;right:.5rem;font-size:.52rem;font-family:'Space Mono',monospace;color:var(--txt3);}
.drop-zone{border:2px dashed var(--brd2);padding:1.5rem;text-align:center;cursor:pointer;transition:all .2s;background:rgba(0,0,0,.2);margin-bottom:.7rem;}
.drop-zone:hover,.drop-zone.drag-over{border-color:var(--lav);background:rgba(122,111,168,.05);}
.drop-zone-text{font-size:.7rem;color:var(--txt2);font-family:'Space Mono',monospace;}
/* MAP */
.map-wrap{display:grid;grid-template-columns:220px 1fr;gap:.7rem;height:calc(100vh - 130px);}
.map-sidebar{background:var(--card);border:1px solid var(--brd);padding:.8rem;overflow-y:auto;display:flex;flex-direction:column;gap:.6rem;}
#mapContainer{border:1px solid var(--brd);position:relative;}
.leaflet-container{background:#0d0d10;}
.map-legend{display:flex;flex-direction:column;gap:.3rem;}
.legend-item{display:flex;align-items:center;gap:.5rem;font-size:.62rem;color:var(--txt2);}
.legend-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.marker-list,.route-list{display:flex;flex-direction:column;gap:.3rem;max-height:150px;overflow-y:auto;}
.marker-item{padding:.35rem .5rem;background:var(--bg3);border:1px solid var(--brd);font-size:.62rem;cursor:pointer;display:flex;align-items:center;gap:.4rem;transition:border-color .15s;}
.marker-item:hover{border-color:var(--red);}
.route-item{padding:.3rem .5rem;background:var(--bg3);border:1px solid var(--brd);font-size:.6rem;display:flex;align-items:center;gap:.4rem;}
/* LOG */
.log-item{display:flex;gap:.8rem;padding:.5rem .6rem;border-bottom:1px solid rgba(34,34,58,.3);font-size:.65rem;align-items:flex-start;}
.log-item:hover{background:rgba(122,111,168,.03);}
.log-type{width:6px;flex-shrink:0;align-self:stretch;border-radius:1px;}
.log-type.add{background:#2dcc70;}.log-type.edit{background:var(--lav);}.log-type.del{background:var(--red2);}.log-type.other{background:var(--txt3);}
.log-ts{font-family:'Space Mono',monospace;color:var(--txt3);font-size:.55rem;white-space:nowrap;}
.log-actor{color:var(--lav2);font-weight:600;}
.log-msg{flex:1;color:var(--txt2);}
/* SETTINGS */
.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;}
.settings-section{background:var(--card);border:1px solid var(--brd);padding:1rem;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,0 100%);position:relative;}
.settings-section-title{font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--red2);margin-bottom:.8rem;padding-bottom:.4rem;border-bottom:1px solid var(--brd2);font-family:'Space Mono',monospace;}
.settings-row{display:flex;align-items:center;gap:.8rem;margin-bottom:.7rem;}
.settings-label{font-size:.65rem;color:var(--txt);flex:1;font-weight:500;}
.settings-sublabel{font-size:.55rem;color:var(--txt2);font-family:'Space Mono',monospace;display:block;margin-top:.1rem;}
.toggle-wrap{position:relative;width:38px;height:20px;flex-shrink:0;}
.toggle-input{opacity:0;width:0;height:0;position:absolute;}
.toggle-slider{position:absolute;inset:0;background:var(--bg3);border:1px solid var(--brd2);cursor:pointer;transition:.2s;border-radius:10px;}
.toggle-slider::before{content:'';position:absolute;height:14px;width:14px;left:2px;bottom:2px;background:var(--txt2);transition:.2s;border-radius:50%;}
.toggle-input:checked+.toggle-slider{background:var(--red);border-color:var(--red);}
.toggle-input:checked+.toggle-slider::before{transform:translateX(18px);background:#fff;}
.color-swatch-row{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.4rem;}
.color-swatch{width:22px;height:22px;border-radius:2px;cursor:pointer;border:2px solid transparent;transition:all .15s;flex-shrink:0;}
.color-swatch.active{border-color:#fff;transform:scale(1.15);box-shadow:0 0 6px rgba(255,255,255,.3);}
.color-swatch:hover{transform:scale(1.1);}
.settings-preview{background:var(--bg3);border:1px solid var(--brd2);padding:.6rem;margin-top:.6rem;}
.settings-preview-label{font-size:.5rem;letter-spacing:.15em;color:var(--txt3);font-family:'Space Mono',monospace;margin-bottom:.3rem;}
.preview-bar{height:4px;border-radius:2px;margin-bottom:.3rem;transition:background .3s,width .3s;}
.preview-txt{font-size:.6rem;color:var(--txt2);}
/* TERMINAL */
.term-line{opacity:0;transform:translateX(-8px);animation:termIn .18s forwards;}
@keyframes termIn{to{opacity:1;transform:translateX(0);}}
.term-cursor{display:inline-block;width:7px;height:.9em;background:var(--red2);vertical-align:middle;animation:blink .8s step-end infinite;margin-left:2px;}
@keyframes blink{50%{opacity:0;}}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--brd2);}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.anim{animation:fadeUp .3s ease forwards;opacity:0;}
.anim-d1{animation-delay:.05s;}.anim-d2{animation-delay:.1s;}.anim-d3{animation-delay:.15s;}
@keyframes shimmerLine{0%{transform:translateX(-100%);}100%{transform:translateX(100vw);}}
.loading-bar{height:1px;background:linear-gradient(90deg,transparent,var(--red),transparent);position:fixed;top:36px;left:0;width:100%;animation:shimmerLine .4s ease forwards;z-index:200;}
</style>
</head>
<body>

          </div>
        </div>
      </div>
    </div>`;
  }).join('')||'<div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--txt3);font-family:\'Space Mono\',monospace;font-size:.65rem;">// NO ALLIANCES REGISTERED //</div>';
  initAllianceCharts();
}
function initAllianceCharts(){
  const types=['Allied','Neutral','Hostile','Pending','Dissolved'];const counts=types.map(t=>S.alliances.filter(a=>a.type===t).length);const colors=types.map(t=>ALLIANCE_COLORS[t]);
  const atc=document.getElementById('allianceTypeChart');
  if(atc){if(allianceTypeChartInst)allianceTypeChartInst.destroy();allianceTypeChartInst=new Chart(atc,{type:'doughnut',data:{labels:types,datasets:[{data:counts,backgroundColor:colors.map(c=>c+'99'),borderColor:colors,borderWidth:1}]},options:{responsive:true,maintainAspectRatio:true,plugins:{legend:{labels:{color:'#7878a0',font:{family:'Space Mono',size:9}}}},animation:{animateRotate:true,duration:700}}});}
  const tiers=[1,2,3,4,5];const tierCounts=tiers.map(t=>S.alliances.filter(a=>a.tier===t).length);
  const ttc=document.getElementById('allianceTierChart');
  if(ttc){if(allianceTierChartInst)allianceTierChartInst.destroy();allianceTierChartInst=new Chart(ttc,{type:'bar',data:{labels:tiers.map(t=>'Tier '+t),datasets:[{label:'Alliances',data:tierCounts,backgroundColor:hexToRgba(SETTINGS.primaryColor,.5),borderColor:SETTINGS.primaryColor,borderWidth:1}]},options:{responsive:true,maintainAspectRatio:true,scales:{x:{ticks:{color:'#7878a0',font:{family:'Space Mono',size:9}},grid:{color:'#22223a'}},y:{ticks:{color:'#7878a0',font:{family:'Space Mono',size:9}},grid:{color:'#22223a'},beginAtZero:true}},plugins:{legend:{display:false}},animation:{duration:600}}});}
}

// ─── GUBE ───
function initGUBE(){renderGubeEvents();const c=document.getElementById('gubeChart');if(c&&!gubeChartInst)gubeChartInst=new Chart(c,{type:'line',data:{labels:[],datasets:[]},options:gubeOpts()});const sc=document.getElementById('gubeStabilityChart');if(sc&&!gubeStabChartInst)gubeStabChartInst=new Chart(sc,{type:'bar',data:{labels:[],datasets:[]},options:{responsive:true,maintainAspectRatio:false,scales:{x:{ticks:{color:'#7878a0',font:{family:'Space Mono',size:9}},grid:{color:'#22223a'}},y:{ticks:{color:'#7878a0',font:{family:'Space Mono',size:9}},grid:{color:'#22223a'}}},plugins:{legend:{labels:{color:'#7878a0',font:{family:'Space Mono',size:9}}}}}});}
function gubeOpts(){return{responsive:true,maintainAspectRatio:false,scales:{x:{ticks:{color:'#7878a0',font:{family:'Space Mono',size:9}},grid:{color:'#22223a'}},y:{ticks:{color:'#7878a0',font:{family:'Space Mono',size:9}},grid:{color:'#22223a'}}},plugins:{legend:{labels:{color:'#a0a0c0',font:{family:'Space Mono',size:9}}}},elements:{line:{tension:.4},point:{radius:2}},animation:{duration:1000,easing:'easeInOutCubic'}};}
function addGubeEvent(){S.gubeEvents.push({delta:1,weight:.5});renderGubeEvents();}
function renderGubeEvents(){const el=document.getElementById('gubeEvents');el.innerHTML=S.gubeEvents.map((ev,i)=>`<div class="event-row"><span style="font-size:.55rem;font-family:'Space Mono',monospace;color:var(--txt3);width:20px;">δ${i+1}</span><input type="number" value="${ev.delta}" step="0.1" onchange="S.gubeEvents[${i}].delta=+this.value"><span style="font-size:.55rem;font-family:'Space Mono',monospace;color:var(--txt3);width:16px;">w</span><input type="number" value="${ev.weight}" min="0" max="5" step="0.05" onchange="S.gubeEvents[${i}].weight=+this.value" style="max-width:60px;"><button onclick="S.gubeEvents.splice(${i},1);renderGubeEvents();" style="background:none;border:none;color:var(--red2);cursor:pointer;font-size:.8rem;">✕</button></div>`).join('');}
function fbFn(s,t){switch(t){case'pos':return .1*s;case'neg':return -.1*s;case'sin':return Math.sin(s*.1)*10;case'log':return Math.log(Math.abs(s)+1)*Math.sign(s);default:return 0;}}
function runGUBE(){
  const s0=parseFloat(document.getElementById('gubeS0').value)||50,alpha=parseFloat(document.getElementById('alphaSlider').value),theta=parseFloat(document.getElementById('thetaSlider').value),steps=parseInt(document.getElementById('stepsSlider').value),fbType=document.getElementById('feedbackType').value;
  const sum=S.gubeEvents.reduce((a,e)=>a+e.weight*e.delta,0);
  function sim(s0,as,ds){const st=[s0];let s=s0;for(let t=0;t<steps;t++){s=s+ds*sum+as*alpha*fbFn(s,fbType);st.push(Math.round(s*100)/100);}return st;}
  const c1=sim(s0,1,1),c2=sim(s0,1,1.1),c3=sim(s0,2,1);
  const labels=Array.from({length:steps+1},(_,i)=>`t${i}`);
  if(gubeChartInst){gubeChartInst.data.labels=labels;gubeChartInst.data.datasets=[{label:'Case-1 Baseline',data:c1,borderColor:SETTINGS.primaryColor,backgroundColor:hexToRgba(SETTINGS.primaryColor,.08),fill:true},{label:'Case-2 Perturbed',data:c2,borderColor:SETTINGS.secondaryColor2,backgroundColor:hexToRgba(SETTINGS.secondaryColor,.08),fill:true},{label:'Case-3 Amplified',data:c3,borderColor:'#2dcc70',backgroundColor:'rgba(45,200,110,.06)',fill:true}];gubeChartInst.update();}
  const sv=c1.map(s=>Math.abs(alpha*fbFn(s,fbType)));
  if(gubeStabChartInst){gubeStabChartInst.data.labels=labels;gubeStabChartInst.data.datasets=[{label:'α·F(S(t))',data:sv,backgroundColor:sv.map(v=>v>theta?'rgba(156,32,48,.7)':'rgba(45,200,110,.5)'),borderColor:'transparent'},{label:'Threshold Θ',data:Array(steps+1).fill(theta),borderColor:'#ffb400',borderDash:[4,4],type:'line',fill:false,pointRadius:0}];gubeStabChartInst.update();}
  const maxFB=Math.max(...sv);const sb=document.getElementById('gubeStabilityBox');
  if(sb){let cls,msg;if(maxFB<=theta*.7){cls='stability-stable';msg='✓ STABLE — Feedback within safe bounds';}else if(maxFB<=theta){cls='stability-warning';msg='⚠ WARNING — Approaching threshold';}else{cls='stability-unstable';msg='✕ UNSTABLE — Threshold exceeded. Apply damping.';}sb.innerHTML=`<div class="stability-indicator ${cls}">${msg}<br><span style="font-size:.55rem;opacity:.7;">MAX α·F = ${maxFB.toFixed(3)} · Θ = ${theta}</span></div>`;}
  const cs=document.getElementById('gubeCaseStates');const cases=[c1,c2,c3];const names=['BASELINE','PERTURBED','AMPLIFIED'];const clss=['case-0','case-1','case-2'];const maxS=Math.max(...[...c1,...c2,...c3].map(Math.abs));
  if(cs)cs.innerHTML=`<div style="padding:.6rem;background:var(--card);border:1px solid var(--brd);"><div class="chart-label">FINAL STATES</div>${cases.map((c,i)=>{const f=c[c.length-1],pct=maxS>0?Math.min(Math.abs(f)/maxS*100,100):0;return`<div class="gube-state-bar ${clss[i]}"><span style="width:90px;color:var(--txt2);">${names[i]}</span><div style="flex:1;height:8px;background:var(--bg3);border-radius:1px;"><div class="gube-state-fill" style="width:${pct}%;"></div></div><span style="width:60px;text-align:right;color:var(--txt);">${f.toFixed(2)}</span></div>`;}).join('')}</div>`;
  logEvent('other',`GUBE simulation — α=${alpha}, Θ=${theta}, steps=${steps}`);saveState();
}
function resetGUBE(){if(gubeChartInst){gubeChartInst.data.labels=[];gubeChartInst.data.datasets=[];gubeChartInst.update();}if(gubeStabChartInst){gubeStabChartInst.data.labels=[];gubeStabChartInst.data.datasets=[];gubeStabChartInst.update();}const sb=document.getElementById('gubeStabilityBox');if(sb)sb.innerHTML='';const cs=document.getElementById('gubeCaseStates');if(cs)cs.innerHTML='';}

// ─── SFN ───
function renderSFN(){document.getElementById('sfnAssetVal').textContent=S.sfn.assets;renderSFNTable();initSFNChart();}
function sfnAdjust(n){S.sfn.assets=Math.max(0,S.sfn.assets+n);S.sfn.assetHistory.push({val:S.sfn.assets,ts:new Date().toISOString()});logEvent('edit',`SFN assets adjusted to ${S.sfn.assets}`);saveState();renderSFN();renderDashboard();}
function sfnSetAsset(){const v=parseInt(prompt('Set asset count:'));if(isNaN(v))return;S.sfn.assets=Math.max(0,v);S.sfn.assetHistory.push({val:S.sfn.assets,ts:new Date().toISOString()});logEvent('edit',`SFN assets set to ${S.sfn.assets}`);saveState();renderSFN();renderDashboard();}
function renderSFNTable(){const el=document.getElementById('sfnMemberTable');if(!el)return;el.innerHTML=S.sfn.members.map((m,i)=>`<tr class="term-line" style="animation-delay:${i*.04}s"><td><input type="checkbox" class="sfn-chk" data-idx="${i}"></td><td><b>${m.name}</b></td><td style="color:var(--lav2);">${m.social||'—'}</td><td style="font-family:'Space Mono',monospace;font-size:.62rem;color:var(--txt2);">${m.phone||'—'}</td><td><button class="btn btn-danger btn-sm" onclick="deleteSFNMember(${i})" style="clip-path:none;">✕</button></td></tr>`).join('')||'<tr><td colspan="5" style="color:var(--txt3);font-size:.62rem;padding:.6rem;font-family:\'Space Mono\',monospace;">// NO MEMBERS LOGGED //</td></tr>';}
function saveSFNMember(){const m={name:document.getElementById('sfnName').value.trim(),social:document.getElementById('sfnSocial').value.trim(),phone:document.getElementById('sfnPhone').value.trim(),ts:new Date().toISOString()};if(!m.name)return;S.sfn.members.push(m);logEvent('add',`SFN member logged: "${m.name}"`);saveState();closeModal('sfnModal');renderSFNTable();}
function deleteSFNMember(i){const n=S.sfn.members[i].name;if(!confirm(`Remove SFN member "${n}"?`))return;S.sfn.members.splice(i,1);logEvent('del',`SFN member "${n}" removed`);saveState();renderSFNTable();}
function toggleSFNAll(cb){document.querySelectorAll('.sfn-chk').forEach(c=>c.checked=cb.checked);}
function initSFNChart(){const canvas=document.getElementById('sfnChart');if(!canvas)return;const hist=S.sfn.assetHistory.slice(-15);if(sfnChartInst)sfnChartInst.destroy();sfnChartInst=new Chart(canvas,{type:'line',data:{labels:hist.map((_,i)=>`#${i+1}`),datasets:[{label:'Assets',data:hist.map(h=>h.val),borderColor:SETTINGS.primaryColor,backgroundColor:hexToRgba(SETTINGS.primaryColor,.1),fill:true,tension:.4,pointRadius:3,pointBackgroundColor:SETTINGS.primaryColor2}]},options:{responsive:true,maintainAspectRatio:false,scales:{x:{ticks:{color:'#5a5a7a',font:{family:'Space Mono',size:8}},grid:{color:'#1a1a2a'}},y:{ticks:{color:'#5a5a7a',font:{family:'Space Mono',size:8}},grid:{color:'#1a1a2a'}}},plugins:{legend:{display:false}},animation:{duration:600}}});}

// ─── TRACKER ───
function getFileType(n){const e=(n.split('.').pop()||'').toLowerCase();if(['json'].includes(e))return'json';if(['txt','md','log','csv'].includes(e))return'text';if(['png','jpg','jpeg','gif','webp','svg'].includes(e))return'image';return'other';}
function getFileIcon(t){return{json:'{ }',text:'≡',image:'⬡',other:'▣'}[t]||'▣';}
function formatBytes(b){if(b<1024)return b+' B';if(b<1048576)return(b/1024).toFixed(1)+' KB';return(b/1048576).toFixed(1)+' MB';}
function renderTracker(){
  const search=(document.getElementById('trackerSearch')?.value||'').toLowerCase();const filter=document.getElementById('trackerFilter')?.value||'';
  const files=S.tracker.filter(f=>f.name.toLowerCase().includes(search)&&(!filter||f.type===filter));
  document.getElementById('trackerCount').textContent=`${files.length} file${files.length!==1?'s':''}`;
  const grid=document.getElementById('trackerGrid');if(!grid)return;
  grid.innerHTML=files.map((f,i)=>`<div class="tracker-card term-line" style="animation-delay:${i*.04}s" onclick="viewTrackerFile(${S.tracker.indexOf(f)})"><div class="tracker-size">${formatBytes(f.size||0)}</div><div class="tracker-icon">${getFileIcon(f.type)}</div><div class="tracker-name" title="${f.name}">${f.name}</div><div class="tracker-meta">${f.type.toUpperCase()} · ${new Date(f.ts).toLocaleDateString()}</div></div>`).join('')||'<div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--txt3);font-family:\'Space Mono\',monospace;font-size:.65rem;">// NO FILES STORED //</div>';
}
function viewTrackerFile(i){const f=S.tracker[i];document.getElementById('trackerViewTitle').textContent=f.name;let p='';try{p=JSON.stringify(JSON.parse(f.content),null,2);}catch(e){p=f.content||'[Binary — no preview]';}if(p.length>3000)p=p.slice(0,3000)+'\n... [truncated]';document.getElementById('trackerViewContent').textContent=p;document.getElementById('trackerViewDel').onclick=()=>{deleteTrackerFile(i);closeModal('trackerViewModal');};document.getElementById('trackerViewDl').onclick=()=>downloadTrackerFile(i);openModal('trackerViewModal');}
function deleteTrackerFile(i){const n=S.tracker[i].name;S.tracker.splice(i,1);logEvent('del',`File "${n}" deleted`);saveState();renderTracker();}
function downloadTrackerFile(i){const f=S.tracker[i];const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([f.content],{type:'text/plain'}));a.download=f.name;a.click();}
function uploadTrackerFile(e){[...e.target.files].forEach(file=>{const r=new FileReader();r.onload=ev=>{S.tracker.push({name:file.name,type:getFileType(file.name),content:ev.target.result,size:file.size,ts:new Date().toISOString()});logEvent('add',`File "${file.name}" uploaded`);saveState();renderTracker();};r.readAsText(file);});e.target.value='';}
function importTrackerFile(e){const file=e.target.files[0];if(!file)return;const r=new FileReader();r.onload=ev=>{S.tracker.push({name:file.name,type:'json',content:ev.target.result,size:file.size,ts:new Date().toISOString()});logEvent('add',`JSON imported: "${file.name}"`);saveState();renderTracker();};r.readAsText(file);e.target.value='';}
function dragOver(e){e.preventDefault();document.getElementById('dropZone').classList.add('drag-over');}
function dragLeave(e){document.getElementById('dropZone').classList.remove('drag-over');}
function dropFile(e){e.preventDefault();dragLeave(e);[...e.dataTransfer.files].forEach(file=>{const r=new FileReader();r.onload=ev=>{S.tracker.push({name:file.name,type:getFileType(file.name),content:ev.target.result,size:file.size,ts:new Date().toISOString()});logEvent('add',`File "${file.name}" dropped`);saveState();renderTracker();};r.readAsText(file);});}

// ─── MAP ───
let map,placing=false,routeMode=false,routeStart=null,leafletMarkers=[],leafletRoutes=[],mapInitialized=false;
const MARKER_COLORS={post:'#9c2030',import:'#7a6fa8',export:'#2dcc70',homeland:'#ffb400'};
const MARKER_LABELS={post:'Post',import:'Import Depot',export:'Export Depot',homeland:'Main Homeland'};
function initMap(){if(mapInitialized){refreshMapMarkers();renderMapSidebar();return;}mapInitialized=true;map=L.map('mapContainer',{preferCanvas:true}).setView([20,0],2);L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'©OpenStreetMap ©CartoDB',maxZoom:19}).addTo(map);map.on('click',onMapClick);refreshMapMarkers();renderMapSidebar();}
function onMapClick(e){
  if(placing){const name=document.getElementById('markerName').value.trim()||'Location';const type=document.getElementById('markerType').value;S.mapMarkers.push({name,type,lat:e.latlng.lat,lng:e.latlng.lng,id:Date.now()});logEvent('add',`Map marker "${name}" placed [${type}]`);saveState();placing=false;document.getElementById('mapPlaceStatus').textContent='Marker placed!';map.getContainer().style.cursor='';refreshMapMarkers();renderMapSidebar();}
  else if(routeMode){if(!routeStart){routeStart=e.latlng;document.getElementById('routeModeStatus').textContent='Now click the END point';}else{S.mapRoutes.push({from:[routeStart.lat,routeStart.lng],to:[e.latlng.lat,e.latlng.lng],id:Date.now()});logEvent('add','Route line added');saveState();routeMode=false;routeStart=null;document.getElementById('routeModeStatus').textContent='';map.getContainer().style.cursor='';refreshMapMarkers();renderMapSidebar();}}
}
function enableMarkerPlace(){placing=true;map.getContainer().style.cursor='crosshair';document.getElementById('mapPlaceStatus').textContent='Click on the map to place marker';}
function openRouteMode(){routeMode=true;routeStart=null;map.getContainer().style.cursor='crosshair';document.getElementById('routeModeStatus').textContent='Click START point on map';}
function refreshMapMarkers(){leafletMarkers.forEach(m=>map.removeLayer(m));leafletMarkers=[];leafletRoutes.forEach(r=>map.removeLayer(r));leafletRoutes=[];S.mapMarkers.forEach(m=>{const color=MARKER_COLORS[m.type]||'#fff';const icon=L.divIcon({html:`<div style="width:12px;height:12px;background:${color};border:2px solid #fff;border-radius:50%;box-shadow:0 0 8px ${color};"></div>`,className:'',iconSize:[12,12],iconAnchor:[6,6]});const lm=L.marker([m.lat,m.lng],{icon}).addTo(map).bindPopup(`<div style="background:#131320;color:#cccce0;font-family:'Space Mono',monospace;font-size:11px;padding:4px 8px;border:1px solid #9c2030;"><b>${m.name}</b><br>${MARKER_LABELS[m.type]}</div>`);leafletMarkers.push(lm);});S.mapRoutes.forEach(r=>{leafletRoutes.push(L.polyline([r.from,r.to],{color:'#7a6fa8',weight:1.5,opacity:.7,dashArray:'4,4'}).addTo(map));});}
function renderMapSidebar(){const ml=document.getElementById('markerList');if(ml)ml.innerHTML=S.mapMarkers.map((m,i)=>`<div class="marker-item" onclick="flyToMarker(${i})"><div style="width:8px;height:8px;border-radius:50%;background:${MARKER_COLORS[m.type]};flex-shrink:0;"></div><div style="flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">${m.name}</div><button onclick="event.stopPropagation();deleteMarker(${i})" style="background:none;border:none;color:var(--red2);cursor:pointer;font-size:.8rem;">✕</button></div>`).join('')||'<div style="color:var(--txt3);font-size:.6rem;">No markers</div>';document.getElementById('markerCountLabel').textContent=S.mapMarkers.length;const rl=document.getElementById('routeList');if(rl)rl.innerHTML=S.mapRoutes.map((r,i)=>`<div class="route-item"><div style="flex:1;">Route ${i+1}</div><button onclick="deleteRoute(${i})" style="background:none;border:none;color:var(--red2);cursor:pointer;font-size:.8rem;">✕</button></div>`).join('')||'<div style="color:var(--txt3);font-size:.6rem;">No routes</div>';}
function flyToMarker(i){const m=S.mapMarkers[i];map.flyTo([m.lat,m.lng],6,{duration:1});leafletMarkers[i]?.openPopup();}
function deleteMarker(i){const n=S.mapMarkers[i].name;S.mapMarkers.splice(i,1);logEvent('del',`Marker "${n}" deleted`);saveState();refreshMapMarkers();renderMapSidebar();}
function deleteRoute(i){S.mapRoutes.splice(i,1);logEvent('del',`Route ${i+1} deleted`);saveState();refreshMapMarkers();renderMapSidebar();}

// ─── IMPORT/EXPORT ───
function exportData(){const data={...S,exportedAt:new Date().toISOString(),exportedBy:currentUser,version:'2.5'};const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([JSON.stringify(data,null,2)],{type:'application/json'}));a.download=`sevre_db_${Date.now()}.json`;a.click();logEvent('other',`Database exported by ${currentUser}`);saveState();}
function importData(e){const file=e.target.files[0];if(!file)return;const r=new FileReader();r.onload=ev=>{try{const d=JSON.parse(ev.target.result);if(d.members!==undefined){S={...S,...d};delete S.exportedAt;delete S.exportedBy;delete S.version;if(!S.alliances)S.alliances=[];}saveState();logEvent('other',`Database imported from ${file.name}`);renderDashboard();alert('Database imported successfully.');}catch(err){alert('Invalid database file.');}};r.readAsText(file);e.target.value='';}

// ─── INIT ───
function initApp(){loadState();document.getElementById('topUser').textContent=currentUser.toUpperCase();applySettings();updateClock();renderDashboard();initGrowthCharts();const b=document.getElementById('logBadge');if(b)b.textContent=S.log.length;}
window.addEventListener('load',()=>{loadState();bootAnim();if(currentUser){document.getElementById('login').style.display='none';document.getElementById('app').classList.add('active');initApp();}else{applySettings();}document.getElementById('loginName').focus();updateClock();});
</script>

            <div class="form-group"><div class="form-label">THRESHOLD (Θ) <span class="gube-slider-val" id="thetaVal">30</span></div><input class="gube-slider" type="range" min="1" max="100" step="1" value="30" id="thetaSlider" oninput="document.getElementById('thetaVal').textContent=this.value"></div>
            <div class="form-group"><div class="form-label">STEPS <span class="gube-slider-val" id="stepsVal">20</span></div><input class="gube-slider" type="range" min="5" max="50" step="1" value="20" id="stepsSlider" oninput="document.getElementById('stepsVal').textContent=this.value"></div>
            <div class="form-group"><div class="form-label">FEEDBACK TYPE</div>

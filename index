  if(gc){if(growthChartInst)growthChartInst.destroy();growthChartInst=new Chart(gc,{type:'bar',data:{labels:Object.keys(cats),datasets:[{label:'Milestones',data:Object.values(cats),backgroundColor:hexToRgba(SETTINGS.primaryColor,.5),borderColor:SETTINGS.primaryColor,borderWidth:1}]},options:{responsive:true,maintainAspectRatio:true,scales:{x:{ticks:{color:'#7878a0',font:{family:'Space Mono',size:9}},grid:{color:'#22223a'}},y:{ticks:{color:'#7878a0',font:{family:'Space Mono',size:9}},grid:{color:'#22223a'}}},plugins:{legend:{display:false}},animation:{duration:700}}});}
}


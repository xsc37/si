// ─── LOGIN ───
const BOOT_MSGS=['SEVRE INDUSTRIES — OPS CORE v2.5','Initializing secure protocols...','Loading operational database...','Alliance network indexing...','GUBE Engine standby...','Awaiting authentication...'];
function bootAnim(){const el=document.getElementById('bootLines');el.innerHTML='';BOOT_MSGS.forEach((m,i)=>{const d=document.createElement('div');d.className='boot-line';d.style.animationDelay=`${i*.12}s`;d.textContent='> '+m;el.appendChild(d);});}
function attemptLogin(){
  const name=document.getElementById('loginName').value.trim(),soc=document.getElementById('loginSOC').value;
  if(!name){showLoginErr('OPERATOR IDENTIFIER REQUIRED');return;}if(soc!==SOC){showLoginErr('INVALID SOC — ACCESS DENIED');return;}
  currentUser=name;saveState();logEvent('other','Operator '+name+' authenticated');
  document.getElementById('login').style.display='none';document.getElementById('app').classList.add('active');
  document.getElementById('topUser').textContent=name.toUpperCase();initApp();
}
function showLoginErr(msg){const el=document.getElementById('loginErr');el.textContent=msg;setTimeout(()=>el.textContent='',3000);}
document.getElementById('loginSOC').addEventListener('keydown',e=>{if(e.key==='Enter')attemptLogin();});
document.getElementById('loginName').addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('loginSOC').focus();});
function logout(){document.getElementById('app').classList.remove('active');document.getElementById('login').style.display='flex';document.getElementById('loginName').value='';document.getElementById('loginSOC').value='';currentUser='';}

// ─── NAV ───
document.querySelectorAll('.nav-item').forEach(el=>el.addEventListener('click',()=>navigate(el.dataset.tab)));
function navigate(tab){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  const ne=document.querySelector(`.nav-item[data-tab="${tab}"]`);if(ne)ne.classList.add('active');
  const panel=document.getElementById('tab-'+tab);if(panel){panel.classList.add('active');panel.style.animation='none';panel.offsetHeight;panel.style.animation='';}
  showLoading();
  setTimeout(()=>{
    if(tab==='dashboard')renderDashboard();if(tab==='operators')renderOperators();if(tab==='projects')renderProjects();
    if(tab==='growth'){renderMilestones();initGrowthCharts();}if(tab==='gube')initGUBE();if(tab==='sfn')renderSFN();
    if(tab==='alliance')renderAlliances();if(tab==='tracker')renderTracker();if(tab==='map')initMap();
    if(tab==='log')renderLog();if(tab==='settings'){applySettings();initSwatches();}
  },80);
}
function showLoading(){const b=document.getElementById('loadingBar');b.style.display='block';setTimeout(()=>b.style.display='none',500);}
function updateClock(){document.getElementById('topTime').textContent=new Date().toLocaleTimeString('en-US',{hour12:false})+' UTC';}

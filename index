        <button class="logout-btn" onclick="logout()">[ LOG OUT ]</button>
      </div>
    </div>
    <div class="main">

      <!-- DASHBOARD -->
      <div class="tab-panel active" id="tab-dashboard">
        <div class="easter">SËVËRA</div>
        <div class="dash-hero anim">
          <div class="dash-hero-corner"></div>

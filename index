          <div class="alliance-name">${a.name}</div>
        </div>
        <div style="display:flex;align-items:center;gap:.4rem;margin-bottom:.3rem;">
          <span class="badge ${typeBadge[a.type]||'badge-gray'}">${a.type}</span>
          <span style="color:#ffb400;font-size:.7rem;">${stars}</span>
        </div>
        ${a.location?`<div class="alliance-meta">📍 ${a.location}</div>`:''}
        ${a.contact?`<div class="alliance-contact">👤 ${a.contact}</div>`:''}
        ${a.notes?`<div style="font-size:.58rem;color:var(--txt2);margin-top:.3rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${a.notes}">${a.notes}</div>`:''}
        <div class="alliance-footer">
          <span style="font-size:.55rem;font-family:'Space Mono',monospace;color:var(--txt3);">${mc} member${mc!==1?'s':''} · ${a.date||'No date'}</span>
          <div class="alliance-actions">
            <button class="btn btn-lav btn-sm" onclick="editAlliance(${i})" style="clip-path:none;">Edit</button>

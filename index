          <div><div class="page-sub">// GENERALIZED UNIFIED BEHAVIORAL ENGINE</div><div class="page-title"><span>GUBE</span> SIMULATION CORE</div></div>
          <div class="page-actions">
            <button class="btn btn-red btn-sm" onclick="runGUBE()">▶ RUN SIM</button>
            <button class="btn btn-ghost btn-sm" onclick="resetGUBE()">↺ RESET</button>
          </div>
        </div>
        <div class="gube-panel">
          <div class="gube-config">
            <div class="gube-eq">S(t+1) = S(t) + Σ(wᵢ·δᵢ) + α·F(S(t))</div>
            <div class="form-group"><div class="form-label">INITIAL STATE S(0)</div><input class="form-input" id="gubeS0" type="number" value="50" step="0.1"></div>

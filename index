function allianceSelChange(){document.getElementById('allianceBulkBtn').style.display=document.querySelectorAll('.alliance-chk:checked').length?'block':'none';}
function renderAlliances(){
  const search=(document.getElementById('allianceSearch')?.value||'').toLowerCase();
  const tf=document.getElementById('allianceTypeFilter')?.value||'';
  const filtered=S.alliances.filter(a=>(a.name.toLowerCase().includes(search)||(a.contact||'').toLowerCase().includes(search))&&(!tf||a.type===tf));
  document.getElementById('aTotal').textContent=S.alliances.length;
  ['Allied','Neutral','Hostile','Pending'].forEach(t=>{const el=document.getElementById('a'+t);if(el)el.textContent=S.alliances.filter(a=>a.type===t).length;});

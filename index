function saveMilestone(){const m={name:document.getElementById('msName').value.trim(),cat:document.getElementById('msCat').value,date:document.getElementById('msDate').value,done:false};if(!m.name)return;S.milestones.push(m);logEvent('add',`Milestone added: "${m.name}" [${m.cat}]`);saveState();closeModal('milestoneModal');renderMilestones();}

<script>
const SOC='7h-L$';
let currentUser='';
let SETTINGS={darkMode:true,primaryColor:'#9c2030',primaryColor2:'#c02840',secondaryColor:'#7a6fa8',secondaryColor2:'#9d90cc',scanlines:true};
const PRIMARY_PRESETS=['#9c2030','#8b1a2a','#6b1f3a','#1a4a6b','#1a5c2a','#5c3a1a','#4a1a6b','#1a504a'];
const SECONDARY_PRESETS=['#7a6fa8','#6a5f98','#8870b8','#6888a8','#708090','#886870','#688870','#a88060'];
let S={members:[],projects:[],milestones:[],sfn:{assets:0,members:[],assetHistory:[]},log:[],mapMarkers:[],mapRoutes:[],tracker:[],alliances:[],gubeEvents:[{delta:5,weight:.8},{delta:-2,weight:.3},{delta:3,weight:.6}]};
let milestoneChartInst,growthChartInst,gubeChartInst,gubeStabChartInst,sfnChartInst,allianceTypeChartInst,allianceTierChartInst;

function saveState(){localStorage.setItem('sevreDB',JSON.stringify(S));localStorage.setItem('sevreUser',currentUser);localStorage.setItem('sevreSettings',JSON.stringify(SETTINGS));}
function loadState(){
  const d=localStorage.getItem('sevreDB');
  if(d){try{const p=JSON.parse(d);S={...S,...p};if(!S.alliances)S.alliances=[];}catch(e){}}
  currentUser=localStorage.getItem('sevreUser')||'';
  const sv=localStorage.getItem('sevreSettings');
  if(sv){try{SETTINGS={...SETTINGS,...JSON.parse(sv)};}catch(e){}}
}

// ─── SETTINGS ───
function hexToRgba(hex,a){const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return`rgba(${r},${g},${b},${a})`;}
function lightenHex(hex,amt){let r=parseInt(hex.slice(1,3),16)+amt,g=parseInt(hex.slice(3,5),16)+amt,b=parseInt(hex.slice(5,7),16)+amt;r=Math.min(255,Math.max(0,r));g=Math.min(255,Math.max(0,g));b=Math.min(255,Math.max(0,b));return'#'+[r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('');}
function applyColors(){
  const r=document.documentElement;
  r.style.setProperty('--red',SETTINGS.primaryColor);r.style.setProperty('--red2',SETTINGS.primaryColor2);r.style.setProperty('--red-glow',hexToRgba(SETTINGS.primaryColor,.18));
  r.style.setProperty('--lav',SETTINGS.secondaryColor);r.style.setProperty('--lav2',SETTINGS.secondaryColor2);r.style.setProperty('--lav-glow',hexToRgba(SETTINGS.secondaryColor,.15));
  const pp=document.getElementById('primaryColorPicker');if(pp)pp.value=SETTINGS.primaryColor;
  const ph=document.getElementById('primaryColorHex');if(ph)ph.value=SETTINGS.primaryColor;
  const sp=document.getElementById('secondaryColorPicker');if(sp)sp.value=SETTINGS.secondaryColor;
  const sh=document.getElementById('secondaryColorHex');if(sh)sh.value=SETTINGS.secondaryColor;
  const pb=document.getElementById('primaryPreviewBar');if(pb)pb.style.background=SETTINGS.primaryColor;
  const sb2=document.getElementById('secondaryPreviewBar');if(sb2)sb2.style.background=SETTINGS.secondaryColor;
  updateSwatchActive();
}
function applySettings(){
  document.body.classList.toggle('light',!SETTINGS.darkMode);
  const icon=document.getElementById('themeIcon');const lbl=document.getElementById('themeLabel');const sd=document.getElementById('settingDark');
  if(icon)icon.textContent=SETTINGS.darkMode?'☀':'🌙';if(lbl)lbl.textContent=SETTINGS.darkMode?'LIGHT':'DARK';if(sd)sd.checked=SETTINGS.darkMode;
  document.documentElement.style.setProperty('--scanline-opacity',SETTINGS.scanlines?'0.08':'0');
  const ssl=document.getElementById('settingScanline');if(ssl)ssl.checked=SETTINGS.scanlines;
  applyColors();
}
function toggleTheme(){SETTINGS.darkMode=!SETTINGS.darkMode;applySettings();saveState();}
function toggleScanline(){SETTINGS.scanlines=document.getElementById('settingScanline').checked;document.documentElement.style.setProperty('--scanline-opacity',SETTINGS.scanlines?'0.08':'0');saveState();}
function setPrimaryColor(val){if(!/^#[0-9a-fA-F]{6}$/.test(val))return;SETTINGS.primaryColor=val;SETTINGS.primaryColor2=lightenHex(val,30);applyColors();saveState();}
function setSecondaryColor(val){if(!/^#[0-9a-fA-F]{6}$/.test(val))return;SETTINGS.secondaryColor=val;SETTINGS.secondaryColor2=lightenHex(val,30);applyColors();saveState();}
function resetSettings(){if(!confirm('Reset all settings?'))return;SETTINGS={darkMode:true,primaryColor:'#9c2030',primaryColor2:'#c02840',secondaryColor:'#7a6fa8',secondaryColor2:'#9d90cc',scanlines:true};applySettings();initSwatches();saveState();}
function clearAllData(){if(!confirm('WIPE ALL DATA?'))return;if(!confirm('Absolutely sure?'))return;S={members:[],projects:[],milestones:[],sfn:{assets:0,members:[],assetHistory:[]},log:[],mapMarkers:[],mapRoutes:[],tracker:[],alliances:[],gubeEvents:[{delta:5,weight:.8},{delta:-2,weight:.3},{delta:3,weight:.6}]};saveState();renderDashboard();alert('All data cleared.');}
function initSwatches(){
  const ps=document.getElementById('primarySwatches');const ss=document.getElementById('secondarySwatches');
  if(ps)ps.innerHTML=PRIMARY_PRESETS.map(c=>`<div class="color-swatch" style="background:${c};" data-primary="${c}" onclick="setPrimaryColor('${c}')"></div>`).join('');
  if(ss)ss.innerHTML=SECONDARY_PRESETS.map(c=>`<div class="color-swatch" style="background:${c};" data-secondary="${c}" onclick="setSecondaryColor('${c}')"></div>`).join('');

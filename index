          </div>
          <div class="ps5-card" onclick="navigate('alliance')">
            <div class="ps5-card-label">// ALLIANCE NETWORK</div>
            <div class="ps5-card-val" id="d2Alliance">—</div>
            <div class="ps5-card-sub">External relations active</div>
